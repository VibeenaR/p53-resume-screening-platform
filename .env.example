# Copy this file to .env and fill in real values. Never commit .env itself.

# Azure AI Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://resume-doc-intelligence.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=your_key_here

# Azure AI Language
LANGUAGE_ENDPOINT=https://resume-language-service.cognitiveservices.azure.com/
LANGUAGE_KEY=your_key_here

# Azure SQL Database
SQL_SERVER=resume-sql-server.database.windows.net
SQL_DATABASE=ResumeScreeningDB
SQL_USERNAME=sqladmin
SQL_PASSWORD=your_password_here

# Azure Blob Storage
STORAGE_CONNECTION_STRING=your_connection_string_here
STORAGE_CONTAINER=resumes

# Azure Communication Services
COMMUNICATION_CONNECTION_STRING=your_connection_string_here
SENDER_EMAIL=DoNotReply@your-verified-domain.azurecomm.net
